# ============================================
# CREDIT INTELLIGENCE COLOMBIA - CONFIGURACIÓN
# ============================================
# Copia este archivo como .env y completa los valores

# --- SEGURIDAD ---
# Clave secreta de Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=poner_clave_segura_aqui

# Contraseña del panel de administración (/admin/login)
ADMIN_PASSWORD=poner_contraseña_segura_aqui

# Opcional: restringir admin solo a IPs específicas
# Formato: "186.27.64.1, 190.24.0.0/16" (IPs sueltas o rangos CIDR)
# Vacío = permitir cualquier IP
ADMIN_ALLOWED_IPS=

# --- GOOGLE OAUTH (opcional) ---
# Crear en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- SMTP (opcional, para enviar notificaciones) ---
# Para Gmail: usa una "contraseña de aplicación" de 2 pasos
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notificaciones@creditintelligence.co

# --- BASE DE DATOS (PostgreSQL opcional) ---
# Si se define, usa PostgreSQL en vez de SQLite.
# Formato: postgresql://usuario:password@host:puerto/base_de_datos
# Ejemplo Render: postgresql://user:pass@host.render.com:5432/cic_db
# Déjala vacía (o coméntala) para usar SQLite local.
DATABASE_URL=
